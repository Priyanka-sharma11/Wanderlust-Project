<% layout('/layouts/boilerplate')%>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <h3>Create a new listing : </h3>
        <form action="/listings" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">
            <div class="mb-3">
                <lable for="title" class="form-label">Title</lable>
                <input name="title" placeholder="enter a catchy title" type="text" class="form-control" required> 
                <div class="valid-feedback"> Looks good! </div>   
            </div>
            <div class="mb-3">
                <lable for="description" class="form-label">Description</lable>
                <textarea name="description" placeholder="enter description" class="form-control" required></textarea>
                <div class="invalid-feedback">Please enter a short description</div>  
            </div>

            <div class="mb-3 input-group">
                <label class="input-group-text" for="category">Category</label>
                <select class="form-select" id="category" name="category" required>
                  <option>Choose...</option>
                  <option value="trending">Trending</option>
                  <option value="iconicCity">Iconic City</option>
                  <option value="castle">Castle</option>
                  <option value="pool">Pool</option>
                  <option value="mountain">Mountain</option>
                  <option value="room">Rooms</option>
                  <option value="camping">Camping</option>
                  <option value="farm">Farms</option>
                  <option value="arctic">Arctic</option>
                  <option value="boat">Boats</option>
                  <option value="beach">Beach</option>
                </select>
                <div class="invalid-feedback"> Category should be valid</div> 
            </div>

            <div class="mb-3">
                <lable for="image" class="form-label">Upload Listing Image</lable>
                <input name="image" placeholder="enter image URL/LINK" type="file" class="form-control" required>
            </div>  

            <div class="row">
                <div class="mb-3 col-md-4"> 
                    <lable for="price" class="form-label">Price</lable> 
                    <input name="price" placeholder="1200" class="form-control" required>
                    <div class="invalid-feedback"> Price should be valid</div>  
                </div>
                <div class="mb-3 col-md-8">
                    <lable for="country" class="form-label">Country</lable>
                    <input name="country" placeholder="India" type="text" class="form-control" required>
                    <div class="invalid-feedback"> Country name should be valid</div> 
                </div>    
            </div>
            <div class="mb-3">
                <lable for="location" class="form-label">Location</lable>
                <input name="location" placeholder="Jaipur Rajasthan" type="text" class="form-control" required>
                <div class="invalid-feedback"> Location should be valid</div> 
            </div>
    
            <button class="btn btn-dark add-btn mt-3">Add</button>
            <br><br>
        </form>
    </div>  
</div>