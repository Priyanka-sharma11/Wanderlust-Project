<% layout('/layouts/boilerplate')%>


<div id="second-bar">
    <div id="scroll-left">
        <i class="fa-solid fa-circle-arrow-left"></i>
    </div>
    
    <div id="filters">
        <div class="filter">
            <a href="/listings/search/trending">
                <i class="fa-solid fa-fire"></i>
                <p>Trending</p>
            </a>
        </div>
    
        <div class="filter">
            <a href="/listings/search/room">
                <i class="fa-solid fa-bed"></i>
                <p>Rooms</p>
            </a>
        </div>
    
        <div class="filter">
            <a href="/listings/search/mountain">
                <i class="fa-solid fa-mountain"></i>
                <p>Mountains</p>
            </a>
        </div>
    
        <div class="filter">
            <a href="/listings/search/iconicCity">
                <i class="fa-solid fa-mountain-city"></i>
                <p>Iconic Cities</p>
            </a>
        </div>
    
        <div class="filter">
            <a href="/listings/search/castle">
                <i class="fa-brands fa-fort-awesome"></i>
                <p>Castles</p>
            </a>
        </div>
    
        <div class="filter">
            <a href="/listings/search/pool">
                <i class="fa-solid fa-person-swimming"></i>
                <p>Amazing Pools</p>
            </a>
        </div>
        
        <div class="filter">
            <a href="/listings/search/camping">
                <i class="fa-solid fa-campground"></i>
                <p>Camping</p>
            </a>
        </div>
    
        <div class="filter">
            <a href="/listings/search/farm">
                <i class="fa-solid fa-cow"></i>
                <p>Farms</p>
            </a>
        </div>
    
        <div class="filter">
            <a href="/listings/search/arctic">
                <i class="fa-regular fa-snowflake"></i>
                <p>Arctic</p>
            </a>
        </div>
    
        <div class="filter">
            <a href="/listings/search/boat">
                <i class="fa-solid fa-ship"></i>
                <p>Boats</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings/search/beach">
                <i class="fa-solid fa-umbrella-beach"></i>
                <p>Beaches</p>
            </a>
        </div>
    </div>
    
    <div id="scroll-right">
        <i class="fa-solid fa-circle-arrow-right"></i>
    </div>

    <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
          <label class="form-check-label" for="flexSwitchCheckDefault">Display taxes</label>
        </div>
      </div>
    
</div>

<%if(!filter){%>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let listing of allListings){ %>
        <a href="/listings/<%=listing._id%>" class="listing-link">
            <div class="card col listing-card">
                <img src=<%=listing.image.url%> class="card-img-top" alt="listing_image" style="height:20rem">
                <div class="card-img-overlay"></div>
                <div class="card-body">
                    <p class="card-text">
                        <b> <%=listing.title%></b> <br>
                        <span class="price_without_gst">&#8377; <%=listing.price.toLocaleString('en-IN')%>/night</span>

                        <% let withGst = listing.price + ( (listing.price *18)/100)%>
                        <i class="tax-info"> &nbsp; &nbsp; [ +18% GST = &#8377;<%=withGst.toLocaleString('en-IN')%> ]</i>

                    </p>
                </div>
            </div>
        </a>
    <% } %>
</div>
<%}%>

<%if(filter){%>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    
        <% for(let listing of allListings){%>
            <% if(listing.category == filter.filter) { %>
                <a href="/listings/<%=listing._id%>" class="listing-link">
                    <div class="card col listing-card">
                        <img src=<%=listing.image.url%> class="card-img-top" alt="listing_image" style="height:20rem">
                        <div class="card-img-overlay"></div>
                        <div class="card-body">
                            <p class="card-text">
                                <b> <%=listing.title%></b> <br>
                                &#8377; <%=listing.price.toLocaleString('en-IN')%>/night
                                <i class="tax-info"> &nbsp; &nbsp; +18% GST</i>
                            </p>
                        </div>
                    </div>
                </a>    
            <% } %>            
        <% } %> 
    </div>
<%}%>
